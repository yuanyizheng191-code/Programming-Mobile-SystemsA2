{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./",
    "skipLibCheck": true,
    "noEmitOnError": true,
    "allowJs": false
  },
  "include": ["inventory.ts"],
  "exclude": ["inventory.js", "*.js", "dist/**"]
}